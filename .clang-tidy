---
# .clang-tidy — aggressive, pruned for idiomatic C (VM / systems code).
#
# Strategy: enable whole useful families with wildcards, then subtract the
# C++-only families and the individual checks that fight low-level C.

Checks: >
  bugprone-*,
  clang-analyzer-*,
  concurrency-*,
  misc-*,
  performance-*,
  portability-*,
  readability-*,

  -modernize-*,
  -cert-*,
  -cppcoreguidelines-*,
  -hicpp-*,
  -fuchsia-*,
  -llvm-*,
  -llvmlibc-*,
  -google-*,
  -abseil-*,
  -boost-*,
  -mpi-*,
  -openmp-*,
  -zircon-*,
  -android-*,
  -darwin-*,
  -objc-*,
  -altera-*,

  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-function-cognitive-complexity,
  -bugprone-easily-swappable-parameters,
  -misc-no-recursion,
  -bugprone-assignment-in-if-condition,
  -bugprone-multi-level-implicit-pointer-conversion,
  -readability-implicit-bool-conversion,
  -bugprone-multi-level-implicit-pointer-conversion,
  -performance-no-int-to-ptr,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -readability-avoid-nested-conditional-operator

# Nothing is a hard error yet; promote specific checks once the tree is clean,
# e.g. WarningsAsErrors: 'clang-analyzer-*,bugprone-*'
WarningsAsErrors: ''

# Lint your own headers. Narrow to e.g. '^(src|include)/' to skip vendored code.
HeaderFilterRegex: '^enki/'

# Auto-fixes are reformatted using your .clang-format.
FormatStyle: file

CheckOptions:
  # Naming (C conventions). Struct/union/typedef cases are intentionally left
  # unset — add them once you've settled on a convention (e.g. CamelCase types
  # or a `_t` suffix).
  - { key: readability-identifier-naming.FunctionCase,        value: lower_case }
  - { key: readability-identifier-naming.VariableCase,        value: lower_case }
  - { key: readability-identifier-naming.ParameterCase,       value: lower_case }
# - { key: readability-identifier-naming.GlobalConstantCase,  value: UPPER_CASE }
# - { key: readability-identifier-naming.EnumConstantCase,    value: UPPER_CASE }
# - { key: readability-identifier-naming.MacroDefinitionCase, value: UPPER_CASE }
...
