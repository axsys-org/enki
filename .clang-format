---
# .clang-format — C codebase: 2-space indent, K&R / 1TBS attach braces.
Language: Cpp            # clang-format parses C under the "Cpp" language id.
BasedOnStyle: LLVM

# --- Indentation ---
IndentWidth: 2
TabWidth: 2
UseTab: Never
ContinuationIndentWidth: 4
IndentCaseLabels: false  # case labels sit at the switch's indent level

# --- Braces: opening brace on the same line, everywhere (1TBS) ---
BreakBeforeBraces: Attach

# --- Pointers (DEFAULT right-aligned `char *p`; set Left for `char* p`) ---
PointerAlignment: Left
DerivePointerAlignment: false

# --- Line width ---
ColumnLimit: 80          # bump to 100/120 if opcode tables feel cramped

# --- Spacing & alignment ---
AlignAfterOpenBracket: Align
AlignConsecutiveMacros: AcrossComments   # lines up #define opcode tables
AlignTrailingComments: true
SpaceAfterCStyleCast: false
SpacesInParentheses: false

# --- Short constructs: keep them explicit ---
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: false

# --- Includes ---
# Do NOT reorder: a platform/prelude header that must be included first would
# otherwise get sorted ahead/behind and break the build.
SortIncludes: false
IncludeBlocks: Preserve

