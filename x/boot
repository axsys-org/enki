# If you have already started a Reaver session, this will resume from
# snapshot.
#
# Otherwise, it will build reaver, load the standard library, exit,
# and then *then* resume from the new snapshot created through this.

set -ex

BUILD_TYPE=${BUILD_TYPE:-"release"}
PREFIX=${PREFIX-""}
case "${1-}" in
  ''|--reset) ;;
  *) echo "Unknown argument: $1" >&2; exit 1 ;;
esac

do_make () {
  BUILD_TYPE=$BUILD_TYPE make
}


reset () {
	$PREFIX ./build/$BUILD_TYPE/bin/wisp --file-root ./reaver/src ../reaver/src/plan reaver main
}

repl () {
	$PREFIX ./build/$BUILD_TYPE/bin/wisp --file-root ./reaver/src snap root _ # run from snapshot
}

load_stdlib () {
    repl <<EOF
(#bind std (#module std))
(#import std)
EOF
}


do_make

if [[ "$1" == "--reset" || ! -e snap/root.plan ]]
then reset; load_stdlib
fi

repl

